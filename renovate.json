{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeAll",
    ":automergeBranch",
    ":maintainLockFilesWeekly",
    ":semanticCommitTypeAll(chore)"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["!/python/"],
      "rangeStrategy": "pin"
    },
    {
      "matchPackageNames": ["/python/"],
      "enabled": false
    }
  ]
}
